{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "review": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff": "allow",
          "git diff --cached": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git status": "allow"
        },
        "webfetch": "allow",
        "lsp": "allow"
      },
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "color": "#e74c3c"
    }
  }
}